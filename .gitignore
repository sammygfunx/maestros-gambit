# Node dependencies — relay runs `npm ci` on deploy (Render)
server/relay/node_modules/

# Generated test screenshots — regenerate with ?shot= dev hooks
shots/

# Web build: keep the deployable zip in git, ignore the unzipped staging copy
# (it just duplicates the runtime source files)
build/maestros-gambit-web/

# macOS resource forks / metadata
.DS_Store
**/.DS_Store
._*
**/._*

# Claude Code local project settings
.claude/

# promo/: keep the SOURCE deliverables (page copy, checklists, capture scripts) in
# git, but ignore generated/heavy media — they regenerate from the in-game hooks
# (promo/capture_assets.sh) or the in-game reel (js/reel.js), like the shots/ dir.
# (The ScreenFlow project + exported mp4 are ~187MB of local working media.)
promo/trailer_reel.mp4
promo/*.screenflow
promo/screenshots/
promo/.gifframes/
