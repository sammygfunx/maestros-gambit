# Set these in the shell or deployment host. This file is documentation only.
MG_RELAY_HOST=0.0.0.0
# Local override only. On Render/Railway, leave this unset and use their injected PORT.
# MG_RELAY_PORT=8911
MG_RELAY_PATH=/
MG_RELAY_HEALTH_PATH=/healthz
MG_RELAY_ALLOWED_ORIGINS=https://your-maestros-gambit-web-build.example
MG_RELAY_ALLOW_NO_ORIGIN=true
MG_RELAY_ROOM_TTL_SECONDS=3600
MG_RELAY_IDLE_TIMEOUT_SECONDS=120
MG_RELAY_HEARTBEAT_INTERVAL_SECONDS=25
MG_RELAY_CLEANUP_INTERVAL_SECONDS=30
MG_RELAY_MAX_ROOMS=500
MG_RELAY_MAX_PLAYERS_PER_ROOM=2
MG_RELAY_MAX_CLIENTS=1016
MG_RELAY_MAX_MESSAGE_BYTES=262144
MG_RELAY_LOG_LEVEL=info
